# --- OS junk ---
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Editor/IDE ---
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# --- Env / secrets ---
.env
.env.*
!.env.example
*.pem
*.key

# --- Python (api / discovery-worker / generation-worker) ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
alembic/versions/__pycache__/

# --- Node / React / Vite (web) ---
node_modules/
dist/
build/
.vite/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Playwright ---
test-results/
playwright-report/
playwright/.cache/

# --- Temporal ---
*.temporal-worker.log

# --- Logs & temp files ---
*.log
*.tmp
*.bak
*.pid

# --- Unnecessary / generated docs & scratch artifacts ---
# BMAD scratch/working files (design drafts, decision logs) — not deliverables
**/.working/
**/.memlog.md
# Local BMAD user overrides — machine-specific, not shared
_bmad/**/config.user.toml
# Editor/tool-generated doc exports
*.docx#
~$*.docx
~$*.xlsx
~$*.pptx
