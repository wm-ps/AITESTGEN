# --- OS junk ---
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Editor/IDE ---
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# --- Env / secrets ---
.env
.env.*
!.env.example
*.pem
*.key

# --- Python (apps/api, apps/workers/*, packages/*) ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.pyright/
.coverage
htmlcov/
# Note: uv.lock and .python-version are intentionally committed (reproducible
# installs + pinned Python 3.14.6) — do NOT add them here.
# Alembic migration scripts live in migrations/versions/ and ARE committed;
# only their bytecode is ignored (covered by __pycache__/ above).

# --- Node / React / Vite (apps/web) ---
node_modules/
dist/
build/
.vite/
coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
# Note: apps/web/src/api-types.gen.ts is generated from the API's OpenAPI spec
# but IS committed — the CI drift check (AD-6) compares against the checked-in
# copy. Do NOT ignore *.gen.ts.

# --- Playwright ---
test-results/
playwright-report/
playwright/.cache/

# --- Temporal ---
*.temporal-worker.log

# --- Logs & temp files ---
*.log
*.tmp
*.bak
*.pid

# --- Unnecessary / generated docs & scratch artifacts ---
# BMAD scratch/working files (design drafts, decision logs) — not deliverables
**/.working/
**/.memlog.md
# Local BMAD user overrides — machine-specific, not shared
_bmad/**/config.user.toml
# Editor/tool-generated doc exports
*.docx#
~$*.docx
~$*.xlsx
~$*.pptx
